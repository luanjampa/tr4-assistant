# Embeddings — Cloudflare Workers AI (bge-m3, multilíngue, 1024 dim, sem servidor pra manter)
# Token: dash.cloudflare.com > conta > IA > Workers AI > "Crie um token de API Workers AI"
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_EMBED_MODEL=@cf/baai/bge-m3
EMBEDDING_DIM=1024
# AI Gateway (opcional, recomendado): IA > Gateway de AI > Criar gateway > ligar
# "Spend Limits" (valor/mês real, bloqueia ao bater) — sem isso, sem teto de gasto
# nenhum nesse provider. Token: no gateway, "Gateway autenticado > Criar token".
CLOUDFLARE_GATEWAY_ID=
CLOUDFLARE_GATEWAY_TOKEN=

# Chat — Groq (API compatível OpenAI, sem GPU): https://console.groq.com
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.1-8b-instant
MAX_TOKENS_PER_REPLY=700
# Baixa de propósito (padrão do Groq é 1.0) — respostas mais grudadas no
# CONTEXT recuperado, menos alucinação; 0.2 evita ficar 100% determinístico
# (0.0 tende a repetir/loopar nesse modelo).
GROQ_TEMPERATURE=0.2
# Preço por milhão de tokens — ajustar conforme tabela Groq vigente
GROQ_PRICE_IN_PER_M=0.05
GROQ_PRICE_OUT_PER_M=0.08

# Postgres + pgvector (dev local via docker-compose; Railway injeta DATABASE_URL)
DATABASE_URL=postgresql://tr4:tr4@127.0.0.1:5433/tr4

# Paths
TR4_DATA_DIR=./data

# Segurança
TR4_API_KEY=
RATE_LIMIT_PER_MINUTE=20
MAX_MONTHLY_SPEND_USD=5.0
# Cloudflare Turnstile (opcional): https://dash.cloudflare.com/?to=/:account/turnstile
# Sem essas duas, /chat aceita sem captcha e o frontend (GET /ui) não renderiza o widget.
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=

# Facebook batch sync (opcional — preencher quando tiver app Meta aprovado)
# FACEBOOK_ACCESS_TOKEN=
# FACEBOOK_GROUP_ID=
